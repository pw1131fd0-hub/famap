# Sentry Configuration for Error Tracking and Performance Monitoring
# Get your DSN from https://sentry.io after creating a project

# Sentry DSN (Data Source Name) for your project
VITE_SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# Sample rate for performance monitoring (0.0 to 1.0)
# 0.1 = 10% of transactions are tracked (recommended for production)
# 1.0 = 100% of transactions are tracked (use only in development)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Environment (development, staging, production)
# Automatically set based on NODE_ENV but can be overridden
VITE_SENTRY_ENVIRONMENT=production

# Backend API URL
VITE_API_URL=http://localhost:3000/api
